# Production environment for docker/docker-compose.prod.yml.
# Copy to docker/.env.prod and fill in. NEVER commit the real .env.prod.

# ── Image to run (published by CI to GHCR; lowercase owner) ──────────────────
APP_IMAGE=ghcr.io/picklesoda/history-mapped/api:latest

# ── Public domains (Caddy provisions TLS for each) ───────────────────────────
APP_DOMAIN=api.example.org      # API + admin (Inertia) + /docs  -> app container
WEB_DOMAIN=app.example.org      # customer SPA (static, built by the web-build step)

# ── Laravel app ──────────────────────────────────────────────────────────────
APP_NAME=history-mapped
APP_ENV=production
APP_DEBUG=false
# Generate once with:  docker run --rm ghcr.io/picklesoda/history-mapped/api:latest php artisan key:generate --show
APP_KEY=base64:REPLACE_ME
APP_URL=https://api.example.org
LOG_CHANNEL=stderr
OCTANE_SERVER=frankenphp

# ── Database (the in-stack `db` service; or point at managed Postgres) ───────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=history-mapped
DB_USERNAME=history-mapped
DB_PASSWORD=REPLACE_ME_STRONG_PASSWORD
# These three configure the `db` container itself — keep them in sync with DB_* above.
POSTGRES_DB=history-mapped
POSTGRES_USER=history-mapped
POSTGRES_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# ── Cache / queue / session (the in-stack `redis` service) ───────────────────
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ── SPA auth / CORS ──────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=app.example.org
FRONTEND_URL=https://app.example.org

# ── OpenAPI docs (Scramble) — admin-gated unless set true ────────────────────
SCRAMBLE_DOCS_PUBLIC=false
