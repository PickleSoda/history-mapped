# Caddy edge proxy for the production droplet stack.
# Auto-provisions and renews Let's Encrypt TLS for $APP_DOMAIN, then reverse-
# proxies to the FrankenPHP/Octane app container on port 8080.
#
# $APP_DOMAIN is injected from docker/.env.prod via docker-compose.prod.yml.
# For a local/staging host without a public domain, replace "{$APP_DOMAIN}"
# with ":80" to serve plain HTTP.

{$APP_DOMAIN} {
	encode zstd gzip
	reverse_proxy app:8080
}
