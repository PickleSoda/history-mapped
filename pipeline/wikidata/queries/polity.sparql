# POLITY group — political entities, dynasties, persons, military units
#
# This file contains reference SPARQL queries for the POLITY entity group.
# The actual queries are built dynamically in wikidata.py using type_configs.py,
# but these serve as documentation and can be used for manual testing at
# https://query.wikidata.org/

# ── Political Entities (Empires, Kingdoms, Republics, City-States) ──────────

# Fetch historical sovereign states and empires with coordinates and dates
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX schema: <http://schema.org/>
PREFIX wikibase: <http://wikiba.se/ontology#>

SELECT DISTINCT ?item ?itemLabel ?itemDescription ?coord ?inception ?dissolution
       ?wikipedia_title ?governmentForm ?governmentFormLabel ?capital ?capitalLabel
WHERE {
  # Instance of: sovereign state, empire, city-state, historical country
  ?item wdt:P31/wdt:P279* ?class .
  VALUES ?class { wd:Q3624078 wd:Q123480 wd:Q133311 wd:Q3024240 }

  OPTIONAL { ?item wdt:P625 ?coord . }
  OPTIONAL { ?item wdt:P571 ?inception . }
  OPTIONAL { ?item wdt:P576 ?dissolution . }
  OPTIONAL { ?item wdt:P122 ?governmentForm . }
  OPTIONAL { ?item wdt:P36 ?capital . }

  # Only historical (dissolved before 1900) — remove this filter for all
  # FILTER(BOUND(?dissolution) && YEAR(?dissolution) < 1900)

  OPTIONAL {
    ?wikipedia_article schema:about ?item ;
                       schema:isPartOf <https://en.wikipedia.org/> ;
                       schema:name ?wikipedia_title .
  }

  SERVICE wikibase:label { bd:serviceParam wikibase:language "en" . }
}
LIMIT 200


