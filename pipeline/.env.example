# Wikidata / Wikipedia
WIKIDATA_ENDPOINT=https://query.wikidata.org/sparql
WIKIDATA_USER_AGENT=WikiGlobe/1.0 (https://github.com/PickleSoda/WG)
WIKIPEDIA_LANGUAGE=en

# OpenAI (for optional LLM enrichment and embeddings)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SUMMARY_MODEL=gpt-4o-mini
SUMMARY_USE_LLM=false
SUMMARY_MAX_CHARS=420
WIKIPEDIA_EXTRACT_MAX_CHARS=8000

# Output
OUTPUT_DIR=output
LOG_LEVEL=INFO

# Rate limiting
WIKIDATA_REQUESTS_PER_MINUTE=30
WIKIPEDIA_REQUESTS_PER_MINUTE=60
COMMONS_REQUESTS_PER_MINUTE=30

# Database (for direct dedup checks — optional, can use JSONL dedup instead)
DATABASE_URL=postgresql://wikiglobe:secret@localhost:5432/wikiglobe
